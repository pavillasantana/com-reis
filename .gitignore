# ─── Com Réis — .gitignore ─────────────────────────────────────────────────

# ─── Segredos e Ambiente ───────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.p12
*.p8
*.jks
*.keystore
*.key
*.mobileprovision

# ─── Dependências ───────────────────────────────────────────────────────────
node_modules/
.pnp.*
.yarn/

# ─── Builds e Output ───────────────────────────────────────────────────────
dist/
build/
web-build/
*.tsbuildinfo
expo-env.d.ts

# ─── Expo / React Native (pastas geradas) ──────────────────────────────────
.expo/
ios/
android/
.kotlin/
.metro-health-check*
*.orig.*

# ─── Supabase (pastas geradas) ─────────────────────────────────────────────
supabase/.branches
supabase/.temp

# ─── IDEs e Editores ───────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ─── Sistema ────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ─── Logs e Debug ──────────────────────────────────────────────────────────
*.log
npm-debug.*
yarn-debug.*
yarn-error.*
pnpm-debug.*

# ─── Arquivos Temporários / Pessoais ───────────────────────────────────────
anotacoes.txt
TASKS.md
TASK.MD
RELATORIOOPENCODE.TXT
Recording_*.mp4
Testes/
old/
fix_css.js
update_colors.js
migration.sql
migration_*.sql
supabase_setup.sql

# ─── Config de AI Agents (não expor) ───────────────────────────────────────
.agents/
Android/.claude/
Android/CLAUDE.md
Android/AGENTS.md

# ─── Migrations já executadas ──────────────────────────────────────────────
# Se quiser versionar migrations, comente esta linha:
supabase/migrations/
migrations/
